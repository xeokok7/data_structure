#include <stdio.h>

#define SIZE 10

int top = -1;
int S[SIZE];

int push(int num)
{

	if (top == SIZE - 1)	
		return 0;

	S[++top] = num;
}

int pop()
{
	return S[top--];
}

int peek()
{
	return S[top];
}

int main()
{
	int x;
	int y;
	int i;

	printf("push = 1, pop = 2, peek=3, exit = 0 ");

	while (1)
	{
		
		scanf("%d", &x);

		if (x == 1)
		{
			if (top == SIZE - 1)
				printf("스택이 꽉 찼습니다.");
			else
			{
				printf("정수를 입력하세요 : ");
				scanf("%d", &y);

				push(y);

				printf("%d을 넣었습니다.\n현재 스택 : ", y);
			}
		}

		else if (x == 2)
		{
			if (top == -1)
				printf("스택이 없습니다.");
			else
				printf("%d을 빼냈습니다.\n현재 스택 : ", pop());
		}
		else if (x == 0)
			return 0;

		else if (x == 3)
		{
			if (top == -1)
				printf("스택이 없습니다.");
			else
				printf("%d을 추출했습니다.\n현재 스택 : ", peek());
		}
			

		else 
			printf("올바르지 않는 숫자입니다.\n현재 스택 : ");


		for (i = 0; i <= top; i++)
			printf("%d ", S[i]);
		printf("\n");
	}
}
